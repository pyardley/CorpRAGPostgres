# ─────────────────────────────────────────────────────────────────────────────
# CorporateRAG – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App security ──────────────────────────────────────────────────────────────
# Random secret used for Streamlit session signing.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Fernet key for encrypting stored user credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank on first run; the app auto-generates and prints one for you.
ENCRYPTION_KEY=

# ── SQLite (app database) ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./rag_system.db

# ── Pinecone (vector store — free serverless tier) ────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=rag-multi-source
PINECONE_REGION=us-east-1
PINECONE_CLOUD=aws

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: "openai" (recommended) or "huggingface" (zero cost, slower)
EMBEDDINGS_PROVIDER=openai

# Required when EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Used when EMBEDDINGS_PROVIDER=huggingface (no API key needed)
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_DIMENSION=384

# ── LLM ───────────────────────────────────────────────────────────────────────
# Options: "openai", "anthropic", "grok"
LLM_PROVIDER=openai

# OpenAI (default)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic Claude (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Grok / xAI (if LLM_PROVIDER=grok)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-1212

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=8
SCORE_THRESHOLD=0.35
