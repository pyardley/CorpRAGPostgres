# ─────────────────────────────────────────────────────────────────────────────
# CorporateRAG – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App security ──────────────────────────────────────────────────────────────
# Random secret used for Streamlit session signing.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Fernet key for encrypting stored user credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank on first run; the app auto-generates and prints one for you.
ENCRYPTION_KEY=

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
# This single DB stores users, credentials, access rows, AND vector embeddings.
# pgvector must be enabled (CREATE EXTENSION vector) — done automatically on
# first run if your DB role has CREATE permission.
#
# Examples:
#   Local Postgres (Docker / brew / apt):
#     postgresql+psycopg://postgres:postgres@localhost:5432/corporaterag
#
#   Supabase (free tier — pgvector pre-installed):
#     postgresql+psycopg://postgres.<ref>:<pwd>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
#
#   Neon (free tier — pgvector pre-installed):
#     postgresql+psycopg://<user>:<pwd>@ep-cool-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/corporaterag

# Connection pool tuning (defaults work for a single Streamlit process)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: "openai" (recommended) or "huggingface" (zero cost, slower)
EMBEDDINGS_PROVIDER=openai

# Required when EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Used when EMBEDDINGS_PROVIDER=huggingface (no API key needed)
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_DIMENSION=384

# ── LLM ───────────────────────────────────────────────────────────────────────
# Options: "openai", "anthropic", "grok"
LLM_PROVIDER=openai

# OpenAI (default)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic Claude (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Grok / xAI (if LLM_PROVIDER=grok)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-1212

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=8
SCORE_THRESHOLD=0.10
VECTOR_UPSERT_BATCH_SIZE=250

# HNSW runtime search effort (pgvector hnsw.ef_search). The pgvector default
# is 40, which causes recall misses when one source has a dense neighbourhood
# near the query embedding (e.g. many similar marketing emails) and crowds
# out a higher-scoring chunk in another source. 200 is a comfortable default;
# bump to 400+ if you still see noisy-source dominance.
HNSW_EF_SEARCH=200

# Per-source diversity quota. The retriever fetches TOP_K * RETRIEVAL_FETCH_MULTIPLIER
# candidates and then caps how many chunks any single source contributes to
# the final TOP_K. The cap is soft: if other sources don't have enough hits,
# the retriever backfills from the overflow in score order, so single-source
# queries still return a full result set. Set MAX_HITS_PER_SOURCE >= TOP_K
# to disable.
RETRIEVAL_FETCH_MULTIPLIER=4
MAX_HITS_PER_SOURCE=4

# Hybrid retrieval (vector + Postgres FTS, fused with Reciprocal Rank Fusion).
# Solves the rare-token problem (error codes, ticket numbers, identifiers like
# "XYZ999") that pure dense retrieval handles poorly because the embedding is
# dominated by surrounding semantic context, not the literal token.
# Options: "vector" (semantic only) | "hybrid" (semantic + keyword, default).
# Hybrid mode requires the vector_chunks.text_search generated column +
# GIN index, which models/migrations.py provisions automatically.
RETRIEVAL_MODE=hybrid
# RRF smoothing constant. 60 is the original-paper value; rarely worth tuning.
RRF_K=60
# Postgres text-search config. "english" applies stemming + stop-word removal;
# "simple" does neither (better for code-heavy corpora).
FTS_LANGUAGE=english

# ── MCP server (hybrid RAG + live SQL Server table data) ──────────────────────
# The Streamlit app spawns mcp_server/server.py on first authenticated load.
# These settings also apply when running it standalone with:
#     python -m mcp_server.server
# or  uvicorn mcp_server.server:app --port 8765
#
# Bind loopback only by default — the MCP service is internal infrastructure.
MCP_HOST=127.0.0.1
MCP_PORT=8765
# If unset, a fresh token is generated per process and written to
# .streamlit/mcp/token. Set a stable value here when running the MCP server
# as a separate microservice.
MCP_SHARED_TOKEN=
# Hard ceiling on rows returned by any MCP SQL call. The validator clamps
# whatever the LLM asks for to this value.
MCP_SQL_MAX_ROWS=100
MCP_SQL_DEFAULT_ROWS=50
MCP_SQL_QUERY_TIMEOUT_SECONDS=15
MCP_LOG_LEVEL=INFO
